# Better Bedwars Website Configuration

# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-random-secret-string

# Admin
ADMIN_KEY=dev-admin-key
ADMIN_EMAIL=support@betterbedwars.com

# GitHub Repository (pack data source)
GITHUB_REPO_OWNER=betterbedwars
GITHUB_REPO_NAME=betterbedwars-data
GITHUB_REPO_BRANCH=main
GITHUB_PACKS_FILE=packs.json
GITHUB_RAW_URL=https://raw.githubusercontent.com/betterbedwars/betterbedwars-data/main/packs.json
GITHUB_TOKEN=

# Cache durations (in milliseconds)
CACHE_DURATION_PACKS=300000
CACHE_DURATION_METADATA=600000
CACHE_DURATION_STATS=300000
CACHE_DURATION_GALLERY=900000

# Contact form
CONTACT_EMAIL=support@betterbedwars.com
CONTACT_FORM_ENABLED=true

# Server status polling
MINECRAFT_SERVER_HOST=play.betterbedwars.com
MINECRAFT_SERVER_PORT=25565

# Analytics (optional)
GA_TRACKING_ID=
