<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>
  
  <main id="main-content">
    <div class="page-hero">
      <h1>Contact</h1>
      <p>Get in touch with the Better Bedwars team.</p>
    </div>

    <section class="section">
      <div style="display: flex; gap: 60px; flex-wrap: wrap;">
        <!-- Contact Form -->
        <div style="flex: 1; min-width: 300px;">
          <p class="section-title">Send a Message</p>
          <h2 class="section-heading">Contact Form</h2>

          <% if (success) { %>
          <div class="form-success">
            Your message has been sent successfully. We'll get back to you soon!
          </div>
          <% } %>

          <% if (error) { %>
          <div class="form-error">
            <%= error %>
          </div>
          <% } %>

          <form class="contact-form" method="POST" action="/contact">
            <div class="form-group">
              <label class="form-label" for="name">Name</label>
              <input type="text" class="form-input" id="name" name="name" required minlength="2" maxlength="100" placeholder="Your name" value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email</label>
              <input type="email" class="form-input" id="email" name="email" required placeholder="your@email.com" value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="subject">Subject</label>
              <input type="text" class="form-input" id="subject" name="subject" required minlength="2" maxlength="200" placeholder="Subject" value="<%= typeof formData !== 'undefined' && formData.subject ? formData.subject : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="message">Message</label>
              <textarea class="form-textarea" id="message" name="message" required minlength="10" maxlength="5000" placeholder="Your message..."><%= typeof formData !== 'undefined' && formData.message ? formData.message : '' %></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message</button>
          </form>
        </div>

        <!-- Contact Info -->
        <div style="flex: 0 0 320px; min-width: 280px;">
          <p class="section-title">Other Ways</p>
          <h2 class="section-heading">Connect With Us</h2>

          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            </div>
            <div>
              <p class="contact-label">Email</p>
              <p class="contact-value"><a href="mailto:<%= site.supportEmail %>"><%= site.supportEmail %></a></p>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.11 18.1.132 18.115a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
            </div>
            <div>
              <p class="contact-label">Discord</p>
              <p class="contact-value"><a href="<%= social.discord %>" target="_blank" rel="noopener">Join our server</a></p>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </div>
            <div>
              <p class="contact-label">GitHub</p>
              <p class="contact-value"><a href="<%= social.github %>" target="_blank" rel="noopener">betterbedwars</a></p>
            </div>
          </div>

          <div style="margin-top: 32px; padding: 20px; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px;">
            <p style="font-size: 13px; color: #666; line-height: 1.6;">
              <strong style="color: #999;">Response Time:</strong><br>
              We typically respond within 24-48 hours. For urgent matters, join our Discord server for faster support.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>